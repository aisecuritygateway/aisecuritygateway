# ── AISG — AI Security Gateway ────────────────────────────────────────────────
# Copy to .env and fill in your values.
# Add at least one provider key — the gateway routes to any provider with a key.

GATEWAY_PORT=8000
LOG_LEVEL=info
PRESIDIO_WORKERS=1

# Provider API keys (add any you have — leave blank to skip a provider)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
DEEPINFRA_API_KEY=
XAI_API_KEY=

# Gateway API key (clients send this as Bearer token)
AISG_API_KEY=change-me-to-a-real-secret
