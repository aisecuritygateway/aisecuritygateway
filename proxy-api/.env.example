# ── AISG Gateway ───────────────────────────────────────
PORT=8000
LOG_LEVEL=info

# Presidio service URL (set by Docker Compose)
PRESIDIO_URL=http://presidio:3000

# Provider API keys (referenced in gateway.yaml via ${VAR} syntax)
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# Gateway API key (referenced in gateway.yaml)
# AISG_API_KEY=your-secret-gateway-key
